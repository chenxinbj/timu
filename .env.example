# Flask session key. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-with-a-random-long-string

# Admin login. ADMIN_PASSWORD must be set on public/internal servers.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# SQLite database location. Use a persistent server directory.
REVIEW_DB_PATH=/data/timu/review.db

# Hide and disable setup/import actions on deployed servers.
ENABLE_SETUP_ACTIONS=0

# Local app settings for python app.py. Gunicorn sets its own bind address.
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=0
